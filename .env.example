# ===== AI provider mode =====
# Choose how the three reasoning models are invoked.
#   "cli"  → spawn the local `claude`, `codex`, `gemini` binaries (best for local dev)
#   "api"  → call hosted APIs over HTTPS (required for cloud deployments)
#
# Global default for all three providers. Override per-provider below.
AI_MODE=cli

# Per-provider overrides (optional). Leave unset to inherit AI_MODE.
# CLAUDE_MODE=api
# OPENAI_MODE=api
# GEMINI_MODE=api

# ===== Anthropic (Claude) =====
# Required when CLAUDE_MODE=api (or AI_MODE=api).
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-7              # optional override
# ANTHROPIC_BASE_URL=https://api.anthropic.com # optional, for proxies

# ===== OpenAI (Codex / GPT-5.5) =====
# Required when OPENAI_MODE=api (or AI_MODE=api).
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-5.5                         # optional override
# OPENAI_BASE_URL=https://api.openai.com       # optional, for proxies

# ===== Google (Gemini) =====
# Required when GEMINI_MODE=api (or AI_MODE=api).
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-3.1-pro-preview          # optional override
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com  # optional, for proxies

# ===== Wallet / web3 =====
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=demo

# ===== Demo mode =====
# When "true", the app returns mock data instantly and skips external APIs.
NEXT_PUBLIC_DEMO_MODE=false

# ===== On-chain forensics =====
# Etherscan V2 covers Ethereum, Base, Arbitrum, Optimism, Polygon, BSC with one key.
ETHERSCAN_API_KEY=

# ===== Alerts =====
# Strategy alerts are posted here when monitoring triggers.
DISCORD_WEBHOOK_URL=
