# ===== AI provider mode =====
# Choose how the three reasoning models are invoked.
#   "cli"  → spawn the local `claude`, `codex`, `gemini` binaries (best for local dev)
#   "api"  → call hosted APIs over HTTPS (required for cloud deployments)
#
# Global default for all three providers. Override per-provider below.
AI_MODE=cli

# Per-provider overrides (optional). Leave unset to inherit AI_MODE.
# CLAUDE_MODE=api
# OPENAI_MODE=api
# GEMINI_MODE=api

# ===== Anthropic (Claude) =====
# Required when CLAUDE_MODE=api (or AI_MODE=api).
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-7              # optional override
# ANTHROPIC_BASE_URL=https://api.anthropic.com # optional, for proxies

# ===== OpenAI (Codex / GPT-5.5) =====
# Required when OPENAI_MODE=api (or AI_MODE=api).
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-5.5                         # optional override
# OPENAI_BASE_URL=https://api.openai.com       # optional, for proxies

# ===== Google (Gemini) =====
# Required when GEMINI_MODE=api (or AI_MODE=api).
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-3.1-pro-preview          # optional override
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com  # optional, for proxies

# ===== Auth / sessions =====
# Required. HMAC key used to sign the `sov_session` cookie issued by SIWE login.
# Must be >= 32 chars. Routes under /api/strategies* refuse to serve without it.
# Generate with: openssl rand -hex 32
SESSION_SECRET=

# ===== Wallet / web3 =====
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=demo

# ===== RPC providers =====
# wagmi/viem default to public RPCs which rate-limit aggressively. Set ONE of:
#   1) Per-chain explicit URL (highest priority)
#   2) ALCHEMY_API_KEY (auto-builds URLs for ethereum/base/arbitrum/optimism/polygon)
#   3) INFURA_API_KEY (auto-builds URLs for ethereum/arbitrum/optimism/polygon)
# ALCHEMY_API_KEY=
# INFURA_API_KEY=
# RPC_URL_ETHEREUM=
# RPC_URL_BASE=
# RPC_URL_ARBITRUM=
# RPC_URL_OPTIMISM=
# RPC_URL_POLYGON=
# RPC_URL_BSC=

# ===== Demo mode =====
# When "true", the app returns mock data instantly and skips external APIs.
NEXT_PUBLIC_DEMO_MODE=false

# ===== On-chain forensics =====
# Etherscan V2 covers Ethereum, Base, Arbitrum, Optimism, Polygon, BSC with one key.
ETHERSCAN_API_KEY=

# ===== Alerts =====
# Strategy alerts are posted here when monitoring triggers.
DISCORD_WEBHOOK_URL=

# ===== Cron =====
# Bearer token Vercel Cron sends as `Authorization: Bearer <CRON_SECRET>` to
# POST /api/strategies/monitor. Required in production; optional in dev (the
# route runs the in-process scheduler instead). Generate with: openssl rand -hex 32
CRON_SECRET=

# ===== Plans / paywall =====
# Comma-separated lowercase 0x addresses that always resolve to the Ultra tier.
# Useful for the project owner's wallet so testing/demo bypasses the paywall.
# OWNER_WALLETS=0xabc...,0xdef...

# ===== Crypto payments =====
# Defaults are baked into src/lib/payments/config.ts; override here per-deployment.
# All EVM chains (ETH, USDC/USDT on ETH+BSC) settle to the EVM address.
# PAYMENT_ADDRESS_EVM=0x35DE0b4157Ecb2037AB1041d2333981E81BAEF24
# PAYMENT_ADDRESS_BTC=bc1qjuekjcmlxs90cepkp8qtvanj20hamu74f6t8a3
# PAYMENT_ADDRESS_SOL=72FEbjJmA4Ac37gSpceF9KLmamvCY3tBgYRCoarDDFfM
# PAYMENT_ADDRESS_TRON=  # leave unset to disable Tron

# Optional: TronGrid + Solana RPC + mempool.space overrides.
# TRONGRID_API_KEY=
# TRONGRID_API_URL=https://api.trongrid.io
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# MEMPOOL_API_URL=https://mempool.space/api
